# ============================================
# DATABASE - SUPABASE POSTGRESQL
# ============================================
# Connection string desde Supabase → Settings → Database → Connection string
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.lddrseslgkdaetsidyrv:[TU_PASSWORD]@aws-0-sa-east-1.pooler.supabase.co:6543/postgres

# ============================================
# JWT SECRET - GENERAR UNO SEGURO
# ============================================
# Generar con: openssl rand -base64 64
# O usar este comando en Node: require('crypto').randomBytes(64).toString('hex')
JWT_SECRET=cambia-esto-por-un-string-de-64-caracteres-minimo-usa-openssl-rand-base64-64

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# BUSINESS CONFIGURATION
# ============================================
DEFAULT_BUSINESS_ID=00000000-0000-0000-0000-000000000001

# ============================================
# FRONTEND URL (para CORS en producción)
# ============================================
# Cambiar a tu URL de Vercel en producción
FRONTEND_URL=http://localhost:5173

# ============================================
# GOOGLE OAUTH 2.0
# ============================================
# Credenciales desde Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=tu-google-client-id
GOOGLE_CLIENT_SECRET=tu-google-client-secret

# Redirect URI para el callback de Google OAuth
# En desarrollo: http://localhost:3000/api/auth/google/callback
# En producción: https://tu-app.railway.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ============================================
# SUPABASE (opcional, para futuras features)
# ============================================
SUPABASE_URL=https://lddrseslgkdaetsidyrv.supabase.co
SUPABASE_ANON_KEY=sb_publishable_A_WOBMHtH2R22ISC_N-ErA_QLM8uPRs
SUPABASE_SERVICE_ROLE_KEY=[TU_SERVICE_ROLE_KEY]
